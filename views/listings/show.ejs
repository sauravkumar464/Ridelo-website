<script src="/js/map.js"></script>

<script src="https://checkout.razorpay.com/v1/checkout.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf-autotable/3.5.28/jspdf.plugin.autotable.min.js"></script>
<script>
  document.getElementById("pay-btn").addEventListener("click", async (e) => {
    e.preventDefault();

    try {
      // SAFEST FIX → always valid JS
      const amount = Number(<%= JSON.stringify(listing.price) %>) * 100; // Convert ₹ to paise

      const response = await fetch("/listings/create-order", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ amount }),
      });

      const order = await response.json();

      if (!order.id) {
        alert("❌ Failed to create Razorpay order");
        return;
      }

      const options = {
        key: "<%= process.env.RAZORPAY_KEY_ID %>",
        amount: order.amount,
        currency: "INR",
        name: "Ridelo Rentals",
        description: "Listing Payment",
        order_id: order.id,
        handler: function (response) {
          alert("✅ Payment Successful!\nPayment ID: " + response.razorpay_payment_id);
          
          // --- GENERATE PDF RECEIPT ---
          const { jsPDF } = window.jspdf;
          const doc = new jsPDF();
          
          // Company Info
          doc.setFontSize(22);
          doc.setTextColor(40, 40, 40);
          doc.text("Ridelo Rentals", 105, 20, null, null, "center");
          
          doc.setFontSize(12);
          doc.setTextColor(100, 100, 100);
          doc.text("123 Ridelo Avenue, Metropolis", 105, 28, null, null, "center");
          doc.text("support@ridelorentals.com | +91 87892 25659", 105, 34, null, null, "center");
          
          // Divider
          doc.setLineWidth(0.5);
          doc.line(14, 42, 196, 42);
          
          // Receipt Details Header
          doc.setFontSize(16);
          doc.setTextColor(0, 0, 0);
          doc.text("Payment Receipt", 14, 52);
          
          doc.setFontSize(11);
          doc.text(`Receipt Date: ${new Date().toLocaleDateString()}`, 14, 60);
          doc.text(`Payment ID: ${response.razorpay_payment_id}`, 14, 66);
          doc.text(`Order ID: ${response.razorpay_order_id || order.id}`, 14, 72);
          
          // Customer Details
          doc.setFontSize(12);
          doc.text("Customer Details:", 14, 84);
          doc.setFontSize(11);
          doc.setTextColor(80, 80, 80);
          const customerName = "<%= currUser && currUser.username ? currUser.username : 'Guest' %>";
          doc.text(`Name: ${customerName}`, 14, 92);
          
          // Table Data
          doc.autoTable({
            startY: 105,
            head: [['Description', 'Amount']],
            body: [
              [`Vehicle Booking: ${listing.title}`, `Rs. ${listing.price}`],
              ['Status', 'Paid / Success']
            ],
            theme: 'striped',
            headStyles: { fillColor: [51, 153, 204] }
          });
          
          // Footer
          const finalY = doc.lastAutoTable.finalY || 150;
          doc.setFontSize(10);
          doc.text("Thank you for choosing Ridelo Rentals!", 105, finalY + 20, null, null, "center");
          
          // Save the PDF
          doc.save(`Ridelo_Receipt_${response.razorpay_payment_id}.pdf`);
        },
        theme: { color: "#3399cc" },
      };

      const rzp1 = new Razorpay(options);
      rzp1.open();
    } catch (error) {
      console.error(error);
      alert("❌ Something went wrong");
    }
  });
</script>




